iveStreamActive\":false,\"date\":{\"date\":\"2025-03-27T06:00:00+01:00\",\"prefix\":null,\"__typename\":\"RelatedLinkTeaserDate\"},\"live\":null,\"image\":{\"altText\":\"En suddig person med kostym bredvid en skärmdump av ett tweetsvar i sociala medier.\",\"photographer\":\"TT\",\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.54\u002F0.48\u002Fe4fa60a3ea7cc9c32ff21ecc1377f59be83a828e677295a589df004db2ecd719\",\"__typename\":\"Image\"},\"video\":{\"__typename\":\"Video\",\"duration\":102}},{\"__typename\":\"RelatedLinkTeaser\",\"url\":\"\u002Fnyheter\u002Finrikes\u002Frasmus-kamerer-lurad-pa-tiktok-polisen-saknar-statistik\",\"headline\":\"Polisen saknar grepp om Tiktok-bedrägerier – Rasmus Kamerer förlorade tusentals kronor\",\"targetDescription\":null,\"liveStreamActive\":false,\"date\":{\"date\":\"2025-03-24T18:21:41+01:00\",\"prefix\":null,\"__typename\":\"RelatedLinkTeaserDate\"},\"live\":null,\"image\":{\"altText\":\"Tvådelad bild. Vänster: Rasmus Kamerer håller en mobil. Höger: tunnel med texten ”Laziest way to make money online”.\",\"photographer\":\"Douglas Askelöf\",\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.31\u002F0.42\u002F9b22e4af1fccb2261bd14ff77cf216908701283c0ef225538f7db1f41f831c86\",\"__typename\":\"Image\"},\"video\":{\"__typename\":\"Video\",\"duration\":51}},{\"__typename\":\"RelatedLinkTeaser\",\"url\":\"\u002Fnyheter\u002Flokalt\u002Fhalland\u002Fgekas-tidigare-vd-boris-lennerhov-utsatt-for-sms-bedragare-nya-sattet-att-gora-bankran\",\"live\":null,\"headline\":\"Gekås-profilen Boris Lennerhov lurad av SMS-bedragare: ”Nya sättet att göra bankrån”\",\"targetDescription\":null,\"video\":null,\"image\":{\"altText\":\"Boris Lennerhov i kostym på Gekås i Ullared. Kunder syns i bakgrunden.\",\"photographer\":\"ADAM IHSE \u002F TT\",\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.53\u002F0.52\u002Fba111f33d78b2f72611a11844a406b83d96444a1f1ade612cfc151b83fdc9afd\",\"__typename\":\"Image\"},\"liveStreamActive\":false,\"date\":{\"date\":\"2025-03-21T12:50:09+01:00\",\"prefix\":null,\"__typename\":\"RelatedLinkTeaserDate\"}}],\"body\":[{\"__typename\":\"InlineText\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Sedan årsskiftet har polisen börjat se hur bedragare kapar användare på olika sociala medier-appar, för att kunna lura den kapade användarens kontakter på pengar. \"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"– I Sverige är det en ökad intensitet just nu, säger Lotta Mauritzson, från NOA.\"}]}]},{\"__typename\":\"InlineTagBox\",\"tag\":{\"title\":\"nätbedrägerier\",\"url\":\"\u002Fnyheter\u002Fom\u002Fnatbedragerier\",\"__typename\":\"Tag\",\"latest\":[{\"__typename\":\"ListTeaser\",\"url\":\"\u002Fnyheter\u002Finrikes\u002Fexperten-om-attacken-mot-miljodata-sa-kan-dina-uppgifter-anvandas\",\"headline\":\"Experten om attacken mot Miljödata: Så kan dina uppgifter användas\",\"image\":{\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.55\u002F0.41\u002F92f96d0c1446a2e26c2910896a966cbf53b81c554eb655616a7792504d4eb781\",\"photographer\":\"SVT\",\"altText\":\"Måns Jonasson från Internetstiftelsen intervjuas i en tv-studio med stadsvy i bakgrunden.\",\"__typename\":\"Image\"}},{\"__typename\":\"ListTeaser\",\"url\":\"\u002Fnyheter\u002Flokalt\u002Fvast\u002Fstefan-lurades-av-bedragarna-kan-handa-vem-som-helst\",\"headline\":\"Stefan lurades av bedragarna: ”Kan hända vem som helst”\",\"image\":{\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.34\u002F0.51\u002F1c9cf64140c64c65b5d59d031512021d362b28521cf823076ffe6f5198882ef6\",\"photographer\":\"SVT\",\"altText\":\"Stefan Arff sitter i en bil och tittar ut genom fönstret en regnig dag.\",\"__typename\":\"Image\"}}]}},{\"__typename\":\"InlineText\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Enligt Lotta Mauritzson, kan det handla om att uppgifter till en början läcker från ett enskilt konto på en sajt.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"– Då kan de testa det på olika konton och då många har Facebook, kan man använda sig av det, säger Lotta Mauritzson.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Tillvägagångssättet används också för att lura människor vid biljettförsäljning i andra hand, där en bedragare kapar en persons identitet och låtsas vara potentiell säljare.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Lotta Mauritzson säger att bedragarna har förstått att bedrägeriet blir mer trovärdigt om man kapar en riktig identitet, eftersom det är allt vanligare att man kollar upp människor på nätet. \"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"– Vi behöver kolla upp saker och i vissa fall kanske också kontakta säljaren via en annan kanal för att kunna säkerställa att det är en riktig person.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"h4\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Behöver öka säkerheten på nätet\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"I nuläget utreder polisen om det går att spåra bedragarna som har kapat konton. Det pågår också ett arbete för att utreda hur bedragarna lyckas komma åt användares uppgifter.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Samtidigt som polisen ser en ökning av det här fenomenet har antalet anmälningar om just identitetsbedrägerier minskat de senaste åren.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Enligt Lotta Mauritzson vet man ännu inte om det handlar om en verklig nedgång, eller om att drabbade väljer att inte anmäla.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Det är svårt att säga om det kommer att ske en ökning eller stagnering av kapade konton i Sverige. Men Lotta Mauritzson varnar för att vi är relativt oskyddade på nätet.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"– Här behöver man ju jobba med säkerheten kring olika konton och så vidare, för att inte de här kontona ska kunna tas över så enkelt.\"}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"p\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"em\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Se hela inslaget när SVT:s reporter blev själv bedragen av en scammer på konsertbiljetter– som hade kapat någon annans identitet.\"}]}]}]},{\"__typename\":\"InlineFactbox\",\"title\":\"Så skyddar du dig från att bli kapad på nätet\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"ul\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"li\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"strong\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Ha unika lösenord för olika konton \"},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"br\",\"children\":null}]},{\"__typename\":\"TextElement\",\"text\":\"Enligt Lotta Mauritzson kan du exempelvis se till att ha ett unikt lösenord till din mejl. Polisen har bland annat sett att lösenord har läckts från ett enskilt konto, vilket gör att bedragare testar det på andra appar. – Det är jätteviktigt för att många konton återställs genom att skicka e-post till sig själv. Då behöver man ha ett unikt lösenord där man inte använder samma lösenord på något annat konto, säger Lotta Mauritzson. \"}]}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"ul\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"li\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"strong\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Begränsa möjligheten från att bli digital kartlagd\"},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"br\",\"children\":null}]},{\"__typename\":\"TextElement\",\"text\":\"För att skydda dig mot ID-kapning så behöver du begränsa möjligheten att någon kan kartlägga dig som person, och det gör man ofta via sociala medier. \"},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"br\",\"children\":null},{\"__typename\":\"TextElement\",\"text\":\"– Så var försiktig med vad du delar på dina sociala medier. Du kanske inte behöver ta ett kort på nya körkortet och lägga upp en bild, utan det kanske räcker med att du tar ett foto på middagen och så får det var det du delar den dagen, säger Lotta Mauritzson. \"}]}]},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"ul\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"li\",\"children\":[{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"strong\",\"children\":[{\"__typename\":\"TextElement\",\"text\":\"Blir du kapad – kontakta polisen\"},{\"__typename\":\"FormattingElement\",\"attributes\":null,\"type\":\"br\",\"children\":null}]},{\"__typename\":\"TextElement\",\"text\":\"Om du misstänker att du har blivit kapad på din identitet så ska du kontakta polisen så snart som möjligt och kontakta sin bank, om det är så att man misstänker att någon annan har köpt varor eller tjänster i ens namn. Mer information finns på polisens\"},{\"__typename\":\"TextLink\",\"url\":\"https:\u002F\u002Fpolisen.se\u002Futsatt-for-brott\u002Fpolisanmalan\u002Fbedrageri\u002Fbedragerier\u002Fidentitetbedrageri\u002F\",\"ariaLabel\":null,\"children\":[{\"__typename\":\"TextElement\",\"text\":\" hemsida\"}]},{\"__typename\":\"TextElement\",\"text\":\". \"}]}]}]}],\"featuredTag\":{\"title\":\"nätbedrägerier\",\"url\":\"\u002Fnyheter\u002Fom\u002Fnatbedragerier\",\"__typename\":\"Tag\",\"latestArticles\":[{\"style\":\"nyheter\",\"__typename\":\"FeedTeaser\",\"url\":\"\u002Fnyheter\u002Finrikes\u002Fexperten-om-attacken-mot-miljodata-sa-kan-dina-uppgifter-anvandas\",\"headline\":\"Experten: Drabbade något av en måltavla för bedrägerier\",\"headlinePrefix\":null,\"profile\":null,\"text\":\"Så kan uppgifterna användas • ”Kommer låtsas vara någon du känner”\",\"textPrefix\":null,\"image\":{\"altText\":\"Måns Jonasson från Internetstiftelsen intervjuas i en tv-studio med stadsvy i bakgrunden.\",\"photographer\":\"SVT\",\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.55\u002F0.41\u002F92f96d0c1446a2e26c2910896a966cbf53b81c554eb655616a7792504d4eb781\",\"__typename\":\"Image\"},\"video\":{\"__typename\":\"Video\",\"live\":null,\"duration\":89}},{\"style\":\"nyheter\",\"__typename\":\"FeedTeaser\",\"url\":\"\u002Fnyheter\u002Flokalt\u002Fvast\u002Fstefan-lurades-av-bedragarna-kan-handa-vem-som-helst\",\"headline\":\"Stefan lurades av bedragarna: ”Kan hända vem som helst”\",\"headlinePrefix\":null,\"profile\":null,\"text\":\"Liga på 14 personer döms till fängelsestraff\",\"textPrefix\":null,\"image\":{\"altText\":\"Stefan Arff sitter i en bil och tittar ut genom fönstret en regnig dag.\",\"photographer\":\"SVT\",\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.34\u002F0.51\u002F1c9cf64140c64c65b5d59d031512021d362b28521cf823076ffe6f5198882ef6\",\"__typename\":\"Image\"},\"video\":{\"__typename\":\"Video\",\"live\":null,\"duration\":51}},{\"style\":\"nyheter\",\"__typename\":\"FeedTeaser\",\"url\":\"\u002Fnyheter\u002Flokalt\u002Fvasternorrland\u002Fbluff-sms-om-paket-drabbar-tusentals-sa-kanner-du-igen-bedrageriet\",\"headline\":\"Bluff-sms om paket drabbar tusentals  – så känner du igen bedrägeriet\",\"headlinePrefix\":null,\"profile\":null,\"text\":\"Polisen: ”Stort problem som får väldigt stor spridning”\",\"textPrefix\":null,\"image\":{\"altText\":\"En hand håller en mobil med ett bluff-sms om paketleverans på skärmen.\",\"photographer\":\"SVT\",\"urlTemplate\":\"https:\u002F\u002Fwww.svtstatic.se\u002Fimage-news\u002F{{width}}\u002F{{ratio}}\u002F0.39\u002F0.54\u002F714f58ae31601de6835a79c598611e8fc046d8dd58dfdb95fd06df6694092707\",\"__typename\":\"Image\"},\"video\":{\"__typename\":\"Video\",\"live\":null,\"duration\":54}}]}}}"}};
                </script><div id="playerContainer"></div><script type="text/javascript" src="./Facebookbedragerier_files/cast_sender(1).js.download" id="cast-framework"></script><iframe src="./Facebookbedragerier_files/ls.html" height="0" width="0" id="lsframe" style="display: none;"></iframe></body></html>